---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import TrustBanner from '../components/TrustBanner.astro';
---

<BaseLayout title="무료 구독" description="하파의 일일 투자 노트를 매일 아침 무료로 받아보세요.">
  <main class="flex-grow">
    <div class="max-w-xl mx-auto px-6 py-16">
      <div class="text-center mb-10">
        <h1 class="text-2xl font-extrabold text-text mb-3">매일 아침, 투자 노트가 도착합니다</h1>
        <p class="text-text-secondary leading-relaxed">
          하파의 일일 투자 노트를 구독하시면 매일 아침 시장이 열리기 전,<br class="hidden sm:block"/>
          근거 기반 시장 분석과 맞춤 투자 전략을 이메일로 받아보실 수 있습니다.
        </p>
      </div>

      <!-- 혜택 -->
      <div class="bg-bg-secondary rounded-xl p-6 mb-8">
        <h3 class="font-bold text-text mb-4">무료 구독 혜택</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="flex items-start gap-2">
            <span class="text-primary font-bold">&#x2713;</span>
            <span class="text-sm text-text-secondary">매일 아침 시장 분석 노트</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-primary font-bold">&#x2713;</span>
            <span class="text-sm text-text-secondary">오늘의 경제 용어 해설</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-primary font-bold">&#x2713;</span>
            <span class="text-sm text-text-secondary">시드머니별 자산배분 전략</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-primary font-bold">&#x2713;</span>
            <span class="text-sm text-text-secondary">초보자 실수 방지 체크리스트</span>
          </div>
        </div>
      </div>

      <SubscribeForm variant="inline" />

      <TrustBanner variant="full" />

      <!-- VIP 업셀 -->
      <div class="text-center mt-12">
        <h3 class="text-lg font-bold text-text mb-2">더 깊은 분석이 필요하신가요?</h3>
        <p class="text-sm text-text-secondary mb-4">
          VIP 구독으로 시나리오별 투자 전략, 매수/매도 타이밍 가이드,<br class="hidden sm:block"/>
          리스크 관리 프레임워크까지 받아보세요.
        </p>
        <a href="/vip" class="inline-flex items-center justify-center h-10 px-6 rounded-lg border border-vip-gold text-vip-gold font-bold text-sm hover:bg-accent-light transition-colors">
          VIP 구독 알아보기
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
