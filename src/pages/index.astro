---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import CategoryNav from '../components/CategoryNav.astro';

const allPosts = (await getCollection('posts'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const latestPosts = allPosts.slice(0, 6);
---

<BaseLayout title="홈">
  <main class="flex-grow">

    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-primary-dark to-primary py-20 md:py-28">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-5 leading-tight">
          매일 아침, 시장을 읽는 힘을<br class="hidden md:block" />키워드립니다
        </h1>
        <p class="text-lg text-primary-light mb-8 max-w-2xl mx-auto leading-relaxed">
          하파와 함께 근거 기반 시장 분석과 맞춤 투자 전략을 받아보세요.<br class="hidden md:block" />
          주식이 두려운 초보자도 쉽게 이해할 수 있습니다.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/subscribe" class="inline-flex items-center justify-center h-12 px-8 rounded-lg bg-white text-primary-dark font-bold text-base hover:bg-primary-light transition-colors">
            무료 구독 시작하기
          </a>
          <a href="/category/시장분석" class="inline-flex items-center justify-center h-12 px-8 rounded-lg bg-white/10 border border-white/30 text-white font-medium text-base hover:bg-white/20 transition-colors">
            최신 분석 보기
          </a>
        </div>
      </div>
    </section>

    <!-- Trust Indicators -->
    <section class="border-b border-border py-8">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-2xl font-bold text-primary">주 5회</p>
          <p class="text-sm text-text-muted mt-1">매일 시장 분석</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-primary">근거 기반</p>
          <p class="text-sm text-text-muted mt-1">출처 명시 분석</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-primary">초보 맞춤</p>
          <p class="text-sm text-text-muted mt-1">쉬운 용어 해설</p>
        </div>
        <div>
          <p class="text-2xl font-bold text-primary">무료 구독</p>
          <p class="text-sm text-text-muted mt-1">이메일 발송</p>
        </div>
      </div>
    </section>

    <!-- Latest Posts -->
    <section class="py-16 px-6 max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4">
        <div>
          <h2 class="text-2xl font-bold text-text mb-2">최신 투자 노트</h2>
          <p class="text-text-secondary">매일 아침 업데이트되는 시장 분석과 투자 전략</p>
        </div>
        <a class="text-primary hover:text-primary-dark font-medium text-sm flex items-center gap-1" href="/category/시장분석">
          전체 보기 <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <CategoryNav />

      {latestPosts.length === 0 ? (
        <p class="text-center text-text-muted py-16">아직 등록된 포스트가 없습니다.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {latestPosts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              category={post.data.category}
              readingTime={post.data.readingTime}
              slug={post.id}
            />
          ))}
        </div>
      )}
    </section>

    <!-- VIP CTA -->
    <section class="bg-bg-secondary py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-light border border-accent/20 text-vip-gold text-sm font-bold mb-4">
              <span class="material-symbols-outlined text-sm">workspace_premium</span> VIP 프리미엄
            </div>
            <h2 class="text-3xl font-bold text-text mb-4 leading-tight">
              실전 투자 전략을<br/>매일 아침 받아보세요
            </h2>
            <p class="text-text-secondary mb-6 leading-relaxed">
              무료 노트의 교육 콘텐츠를 넘어, 시나리오별 투자 전략과 매수/매도 타이밍 가이드,
              리스크 관리 프레임워크를 제공합니다.
            </p>

            <div class="space-y-3 mb-8">
              <div class="flex items-center gap-3">
                <span class="flex-shrink-0 size-5 rounded-full bg-primary-light text-primary flex items-center justify-center">
                  <span class="material-symbols-outlined text-sm">check</span>
                </span>
                <span class="text-sm text-text-secondary">시나리오별 포지션 전략 (강세/약세/횡보)</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="flex-shrink-0 size-5 rounded-full bg-primary-light text-primary flex items-center justify-center">
                  <span class="material-symbols-outlined text-sm">check</span>
                </span>
                <span class="text-sm text-text-secondary">매수/매도 타이밍 가이드</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="flex-shrink-0 size-5 rounded-full bg-primary-light text-primary flex items-center justify-center">
                  <span class="material-symbols-outlined text-sm">check</span>
                </span>
                <span class="text-sm text-text-secondary">워치리스트 (3~5종목 + 진입 조건)</span>
              </div>
            </div>

            <a href="/vip" class="inline-flex group items-center gap-2 bg-primary text-white hover:bg-primary-dark transition-colors px-6 py-3 rounded-lg font-bold text-sm">
              VIP 구독 알아보기
              <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-0.5">arrow_forward</span>
            </a>
          </div>

          <!-- VIP Card Preview -->
          <div class="relative">
            <div class="bg-bg border border-border rounded-xl p-6 shadow-sm">
              <div class="flex justify-between items-start mb-6">
                <div class="size-10 rounded-lg bg-primary-light flex items-center justify-center text-primary">
                  <span class="material-symbols-outlined">trending_up</span>
                </div>
                <span class="px-2.5 py-1 rounded bg-accent-light text-vip-gold text-xs font-bold">VIP</span>
              </div>
              <h3 class="text-lg font-bold text-text mb-4">오늘의 VIP 투자 전략</h3>
              <div class="space-y-2.5">
                <div class="h-2 w-full bg-surface rounded"></div>
                <div class="h-2 w-5/6 bg-surface rounded"></div>
                <div class="h-2 w-4/6 bg-surface rounded"></div>
              </div>
              <div class="mt-6 pt-4 border-t border-border flex justify-between items-center text-sm text-text-muted">
                <span>프리미엄 전용</span>
                <span class="material-symbols-outlined text-sm">lock</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Subscribe CTA -->
    <section class="py-16 px-6">
      <div class="max-w-xl mx-auto text-center">
        <h2 class="text-2xl font-bold text-text mb-3">무료로 시작하세요</h2>
        <p class="text-text-secondary mb-6">매일 아침 시장이 열리기 전, 근거 기반 투자 노트를 이메일로 받아보세요.</p>
        <a href="/subscribe" class="inline-flex items-center justify-center h-12 px-8 rounded-lg bg-primary text-white font-bold hover:bg-primary-dark transition-colors">
          무료 구독하기
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
