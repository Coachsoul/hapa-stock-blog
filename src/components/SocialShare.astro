---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const fullUrl = new URL(url, Astro.site).toString();
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(fullUrl);
---

<div class="flex items-center gap-3 my-6 py-4 border-t border-b border-border">
  <span class="text-sm font-medium text-text-secondary">공유하기</span>
  <div class="flex gap-2">
    <button class="share-btn kakao size-9 rounded-lg bg-[#FEE500] text-[#3C1E1E] flex items-center justify-center hover:opacity-80 transition-opacity" data-url={fullUrl} data-title={title} aria-label="카카오톡 공유">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3C6.48 3 2 6.46 2 10.64c0 2.68 1.78 5.03 4.44 6.38-.15.56-.96 3.6-.99 3.83 0 0-.02.16.08.22.1.06.22.01.22.01.29-.04 3.37-2.2 3.9-2.57.75.11 1.53.17 2.35.17 5.52 0 10-3.46 10-7.64S17.52 3 12 3z"/>
      </svg>
    </button>

    <a class="size-9 rounded-lg bg-text text-bg flex items-center justify-center hover:opacity-80 transition-opacity" href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="트위터 공유">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>

    <a class="size-9 rounded-lg bg-[#1877F2] text-white flex items-center justify-center hover:opacity-80 transition-opacity" href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank" rel="noopener noreferrer" aria-label="페이스북 공유">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
    </a>

    <button class="copy-link size-9 rounded-lg bg-surface text-text-secondary flex items-center justify-center hover:bg-primary-light hover:text-primary transition-colors" data-url={fullUrl} aria-label="링크 복사">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
      </svg>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll('.copy-link').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = (btn as HTMLElement).dataset.url;
      if (url) {
        await navigator.clipboard.writeText(url);
        const original = btn.innerHTML;
        btn.innerHTML = '<span class="text-xs">복사됨!</span>';
        setTimeout(() => { btn.innerHTML = original; }, 2000);
      }
    });
  });

  document.querySelectorAll('.share-btn.kakao').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const url = el.dataset.url || '';
      const kakaoUrl = `https://story.kakao.com/share?url=${encodeURIComponent(url)}`;
      window.open(kakaoUrl, '_blank', 'width=600,height=400');
    });
  });
</script>
