---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AuthorBio from '../components/AuthorBio.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import SocialShare from '../components/SocialShare.astro';
import TrustBanner from '../components/TrustBanner.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import VipCta from '../components/VipCta.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    tags?: string[];
    keywords?: string[];
    category?: string;
    readingTime?: number;
  };
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
}

const { frontmatter, headings = [], slug } = Astro.props;
const { title, description, pubDate, tags = [], keywords = [], category, readingTime } = frontmatter;
const dateStr = new Date(pubDate).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });

const categoryColors: Record<string, string> = {
  '시장분석': 'bg-primary-light text-primary',
  '종목분석': 'bg-violet-50 text-violet-800',
  '투자전략': 'bg-accent-light text-accent',
  '경제기초': 'bg-teal-50 text-teal-800',
};

const breadcrumbItems = [
  { label: '홈', href: '/' },
  ...(category ? [{ label: category, href: `/category/${category}` }] : []),
  { label: title },
];

const articleSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": new Date(pubDate).toISOString(),
  "author": { "@type": "Person", "name": "하파" },
  "publisher": {
    "@type": "Organization",
    "name": "하파 주식 투자 가이드",
  },
};
---

<BaseLayout title={title} description={description} keywords={keywords} article={true}>
  <ReadingProgress />

  <div class="max-w-6xl mx-auto px-6 py-8 lg:grid lg:grid-cols-[1fr_240px] lg:gap-10">
    <main>
      <article>
        <Breadcrumbs items={breadcrumbItems} />

        <!-- Post Header -->
        <header class="mb-8">
          {category && (
            <span class={`inline-block px-2.5 py-1 rounded text-xs font-semibold mb-3 ${categoryColors[category] || 'bg-surface text-text-secondary'}`}>
              {category}
            </span>
          )}
          <h1 class="text-2xl md:text-3xl font-extrabold text-text leading-tight mb-4">{title}</h1>
          <div class="flex items-center gap-2 text-sm text-text-muted">
            <span>하파</span>
            <span>|</span>
            <span>{dateStr}</span>
            {readingTime && (
              <>
                <span>|</span>
                <span>{readingTime}분 읽기</span>
              </>
            )}
          </div>
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {tags.map((tag: string) => (
                <a href={`/tags/${tag}`} class="text-xs bg-surface text-text-muted px-2 py-0.5 rounded hover:text-primary hover:bg-primary-light transition-colors">#{tag}</a>
              ))}
            </div>
          )}
        </header>

        <!-- Post Content -->
        <div class="post-content">
          <slot />
        </div>

        <VipCta />
        <TrustBanner variant="compact" />
        <SocialShare title={title} url={Astro.url.pathname} />
        <AuthorBio />
        <SubscribeForm variant="card" />
        <RelatedPosts currentSlug={slug} tags={tags} category={category} />
      </article>
    </main>

    <!-- Sidebar: TOC -->
    <TableOfContents headings={headings} />
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
